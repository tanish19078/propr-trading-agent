# Copy to `.env` (repo root) and fill in. `.env` is gitignored.
#
# Propr does not currently expose a separate beta domain to public users.
# Demo (paper) trading runs against api.propr.xyz with a normal pk_live_ key
# and a "Free Trial" challenge attempt. The agent reads account.type from
# the challenge response to know whether it's paper or funded.
#
# Generate the key at: https://app.propr.xyz -> Settings -> API Keys

PROPR_API_KEY=pk_live_paste_yours_here
PROPR_PROFILE=live

# Leave blank to mint a fresh HMAC secret each session.
PROPR_HMAC_SECRET=
